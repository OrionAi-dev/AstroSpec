{
  "name": "mcp-secure-context-sharing",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test --parallel",
    "lint": "turbo run lint --parallel",
    "changeset": "changeset",
    "release:status": "changeset status",
    "version-packages": "changeset version",
    "release:verify": "node tools/check-public-release-packages.mjs && pnpm check:schema-drift && pnpm verify:adoption",
    "release:preflight": "node tools/check-release-preflight.mjs",
    "release:publish": "pnpm release:preflight && changeset publish",
    "docs": "tools/gen-docs.sh",
    "fix:doc-links": "node tools/clean-doc-links.mjs --write",
    "check:duplicate-artifacts": "node tools/check-duplicate-artifacts.mjs",
    "check:schema-drift": "node tools/check-schema-drift.mjs",
    "fix:schema-drift": "node tools/check-schema-drift.mjs --write",
    "check:starconsole-contract-drift": "node tools/check-starconsole-contract-drift.mjs",
    "check:mcp-parity": "node tools/run-package-check.mjs @mcp-secure-context/mcp-adapter",
    "check:retrieval-profile": "node tools/run-package-check.mjs @openspec/retrieval-profile",
    "check:reasoning-profile": "node tools/run-package-check.mjs @openspec/reasoning",
    "check:graph-memory": "node tools/run-package-check.mjs @openspec/graph-memory",
    "check:starburst-profile": "node tools/run-package-check.mjs @openspec/starburst-profile",
    "check:runtime-interfaces": "node tools/run-package-check.mjs @openspec/runtime-interfaces",
    "check:discovery-bundle": "node tools/run-package-check.mjs @openspec/discovery-bundle",
    "smoke:external:mcp-default-fallback": "pnpm exec tsx --tsconfig tsconfig.base.json examples/external/mcp-default-fallback/run.ts",
    "check:public-boundaries": "node tools/check-public-boundaries.mjs",
    "check:deep-imports": "node tools/check-deep-imports.mjs",
    "check:breaking-gate": "node tools/check-breaking-change-gate.mjs",
    "check:secure-context-artifacts": "node tools/check-secure-context-artifacts.mjs",
    "verify:contracts": "node tools/run-package-check.mjs @openspec/agent-contracts && pnpm check:starconsole-contract-drift",
    "verify:adoption": "pnpm check:duplicate-artifacts && pnpm check:public-boundaries && pnpm check:deep-imports && pnpm check:mcp-parity && pnpm check:retrieval-profile && pnpm check:reasoning-profile && pnpm check:graph-memory && pnpm check:starburst-profile && pnpm check:runtime-interfaces && pnpm check:discovery-bundle && pnpm check:secure-context-artifacts && pnpm verify:contracts && pnpm smoke:external:mcp-default-fallback"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.6",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.4",
    "tsup": "8.5.0",
    "turbo": "2.5.6",
    "typedoc": "^0.28.11",
    "typedoc-plugin-markdown": "^4.8.1",
    "typescript": "5.9.2",
    "vitest": "2.1.9",
    "zod": "^3.25.76"
  }
}
