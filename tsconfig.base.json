{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@openspec/schema": ["packages/openspec-schema/src/index.ts"],
      "@openspec/runtime": ["packages/openspec-runtime/src/index.ts"],
      "@openspec/kit": ["packages/openspec-kit/src/index.ts"],
      "@openspec/cli": ["packages/openspec-cli/src/cli.ts"],
      "@openspec/retrieval-profile": ["packages/openspec-retrieval-profile/src/index.ts"],
      "@openspec/reasoning": ["packages/openspec-reasoning/src/index.ts"],
      "@openspec/graph-memory": ["packages/openspec-graph-memory/src/index.ts"],
      "@openspec/starburst-profile": ["packages/openspec-starburst-profile/src/index.ts"],
      "@openspec/runtime-interfaces": ["packages/openspec-runtime-interfaces/src/index.ts"],
      "@openspec/discovery-bundle": ["packages/openspec-discovery-bundle/src/index.ts"],
      "@openspec/agent-contracts": ["packages/openspec-agent-contracts/src/index.ts"],
      "@openspec/mindql-core": ["packages/integrations/mindql-core/src/index.ts"],
      "@openspec/mindgraphql-core": ["packages/integrations/mindgraphql-core/src/index.ts"],
      "@openspec/integration-audio-openai": ["packages/integrations/audio-openai/src/index.ts"],
      "@openspec/integration-events": ["packages/integrations/events/src/index.ts"],
      "@mcp-secure-context/core": ["packages/mcp-secure-context-core/src/index.ts"],
      "@mcp-secure-context/extensions-openspec": ["packages/mcp-secure-context-extensions-openspec/src/index.ts"],
      "@mcp-secure-context/openspec": ["packages/mcp-secure-context-openspec/src/index.ts"],
      "@mcp-secure-context/mcp-adapter": ["packages/mcp-secure-context-mcp-adapter/src/index.ts"],
      "@mcp-secure-context/sdk-typescript": ["packages/mcp-secure-context-sdk-typescript/src/index.ts"],
      "@mcp-secure-context/cli": ["packages/mcp-secure-context-cli/src/cli.ts"]
    }
  },
  "exclude": [
    "node_modules",
    "**/dist/**"
  ]
}
