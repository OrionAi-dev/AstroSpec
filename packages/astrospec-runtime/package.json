{
  "name": "@astrospec/runtime",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Compatibility wrapper for @mcp-secure-context/openspec.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "keywords": [
    "astrospec",
    "compatibility",
    "openspec",
    "context-sharing"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@mcp-secure-context/openspec": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
