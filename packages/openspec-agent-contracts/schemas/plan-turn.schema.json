{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stardrive.dev/starconsole/plan-turn.schema.json",
  "title": "PlanTurn",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "intent",
    "objective",
    "constraints",
    "assumptions",
    "steps",
    "completionChecks"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "intent": { "const": "plan" },
    "objective": { "type": "string", "minLength": 1 },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "riskRollback": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "completionChecks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "riskTier": {
          "type": "string",
          "enum": ["low", "moderate", "high", "critical"]
        },
        "approvalRef": { "type": "string", "minLength": 1 }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "description", "toolIntents", "acceptanceCheck"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "acceptanceCheck": { "type": "string", "minLength": 1 },
          "toolIntents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "mode"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "mode": { "type": "string", "enum": ["read", "write"] },
                "rationale": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
