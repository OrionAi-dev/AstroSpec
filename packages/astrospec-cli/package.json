{
  "name": "@astrospec/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Compatibility wrapper for @mcp-secure-context/cli.",
  "bin": {
    "astrospec": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
