{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.orionai.dev/astrospec/chat-orchestration-audit.schema.json",
  "title": "ChatOrchestrationAudit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "auditVersion",
    "enabled",
    "decisionSource",
    "preference",
    "lanes",
    "fallback",
    "traceId",
    "timingsMs",
    "toolPolicy"
  ],
  "properties": {
    "auditVersion": { "const": "1.0" },
    "enabled": { "type": "boolean" },
    "decisionSource": {
      "type": "string",
      "enum": [
        "flag_off",
        "allowlist_off",
        "user_on",
        "user_off",
        "policy_auto",
        "journal_reflector",
        "event_workflow",
        "forecast_mode"
      ]
    },
    "preference": {
      "type": "string",
      "enum": ["on", "off", "auto"]
    },
    "lanes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planner", "reviewer", "responder"],
      "properties": {
        "planner": { "$ref": "#/$defs/lane" },
        "reviewer": { "$ref": "#/$defs/lane" },
        "responder": { "$ref": "#/$defs/lane" }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["triggered", "target"],
      "properties": {
        "triggered": { "type": "boolean" },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "degradedCode": {
      "type": ["string", "null"],
      "enum": [
        "CHAT_HANDOFF_PROVIDER_TIMEOUT",
        "CHAT_HANDOFF_PROVIDER_AUTH_FAILED",
        "CHAT_HANDOFF_PROVIDER_INVALID_OUTPUT",
        "CHAT_HANDOFF_POLICY_BLOCKED",
        "CHAT_HANDOFF_RUNTIME_UNAVAILABLE",
        "CHAT_HANDOFF_BUDGET_EXCEEDED",
        null
      ]
    },
    "traceId": { "type": "string", "minLength": 8 },
    "timingsMs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "planner": { "type": "integer", "minimum": 0 },
        "reviewer": { "type": "integer", "minimum": 0 },
        "responder": { "type": "integer", "minimum": 0 }
      }
    },
    "toolPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowedTools"],
      "properties": {
        "mode": { "const": "read-only" },
        "allowedTools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blockedTools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "lane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 }
      }
    }
  }
}
