{
  "name": "@openspec/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "OpenSpec CLI entrypoint for validation, verification, and MCP Secure Context Sharing workflows.",
  "bin": {
    "openspec": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --dts --format esm",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "dependencies": {
    "@mcp-secure-context/cli": "workspace:*",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
