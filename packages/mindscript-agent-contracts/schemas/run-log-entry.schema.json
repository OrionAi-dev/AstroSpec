{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stardrive.dev/starconsole/run-log-entry.schema.json",
  "title": "RunLogEntry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "runId", "phase", "createdAt", "status"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "phase": {
      "type": "string",
      "enum": [
        "run.start",
        "memory.query",
        "plan.validated",
        "exec.proposed",
        "tool.executed",
        "tool.denied",
        "awaiting.approval",
        "run.completed",
        "run.failed"
      ]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["ok", "warn", "error"] },
    "reasonCode": { "type": "string" },
    "metadata": { "type": "object", "additionalProperties": true },
    "prevHash": { "type": "string", "minLength": 8 },
    "entryHash": { "type": "string", "minLength": 8 }
  }
}
