{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.stardrive.dev/starconsole/repopack.schema.json",
  "title": "RepoPack",
  "type": "object",
  "additionalProperties": false,
  "required": ["repoRoot", "generatedAt", "files"],
  "properties": {
    "repoRoot": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "rationale", "content"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "content": { "type": "string" }
        }
      }
    }
  }
}
